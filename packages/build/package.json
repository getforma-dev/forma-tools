{
  "name": "@getforma/build",
  "version": "0.1.7",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "author": "Forma <victor@getforma.dev>",
  "homepage": "https://getforma.dev",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --external @getforma/compiler",
    "test": "vitest run"
  },
  "dependencies": {
    "esbuild": "^0.25.0"
  },
  "peerDependencies": {
    "@getforma/compiler": "^0.1.0"
  },
  "peerDependenciesMeta": {
    "@getforma/compiler": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.7.3",
    "vitest": "^3.1.1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/getforma-dev/forma-tools.git",
    "directory": "packages/build"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18"
  }
}
